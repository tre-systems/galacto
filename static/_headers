# Revalidate assets on each load so a redeploy can't pair a cached old
# galacto.js with a fresh galacto_bg.wasm (they are one versioned unit).
# Explicit per-path rules: Cloudflare Pages applies a default max-age to .js
# that a /* rule does not override, but an exact-path rule does.
/galacto.js
  Cache-Control: no-cache
/galacto_bg.wasm
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/*
  Cache-Control: no-cache
