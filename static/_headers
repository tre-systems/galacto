# index.html revalidates on each load, so the ?v= cache-busting below takes
# effect immediately. Cloudflare Pages force-caches static assets (.js, .css,
# .wasm) with a max-age this no-cache can't override, so galacto.js and
# styles.css are cache-busted with a per-deploy ?v= query in index.html instead.
/*
  Cache-Control: no-cache
